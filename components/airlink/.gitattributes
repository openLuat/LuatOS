# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Source files - enforce LF
*.c     text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.cc    text eol=lf
*.lua   text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.cmake text eol=lf
*.mk    text eol=lf
Makefile text eol=lf
*.lua   text eol=lf
*.proto text eol=lf

# Binary files - no conversion
*.bin   binary
*.so    binary
*.dll   binary
*.a     binary
*.lib   binary
*.o     binary
*.obj   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.exe   binary
*.elf   binary
*.hex   binary
